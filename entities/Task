{
  "name": "Task",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "T\u00edtulo da tarefa"
    },
    "description": {
      "type": "string",
      "description": "Descri\u00e7\u00e3o detalhada da tarefa"
    },
    "column": {
      "type": "string",
      "enum": [
        "segunda",
        "terca",
        "quarta",
        "quinta",
        "sexta",
        "urgentes",
        "analisando",
        "concluidos"
      ],
      "description": "Coluna/quadro onde a tarefa est\u00e1"
    },
    "position": {
      "type": "number",
      "description": "Posi\u00e7\u00e3o da tarefa na coluna"
    },
    "labels": {
      "type": "array",
      "description": "Etiquetas da tarefa",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "color": {
            "type": "string"
          }
        }
      }
    },
    "priority": {
      "type": "string",
      "enum": [
        "baixa",
        "media",
        "alta"
      ],
      "default": "media",
      "description": "Prioridade da tarefa"
    },
    "due_date": {
      "type": "string",
      "format": "date",
      "description": "Data de vencimento"
    }
  },
  "required": [
    "title",
    "column"
  ]
}